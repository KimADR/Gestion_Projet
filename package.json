{
  "name": "vacation-management-app",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.2",
  "description": "Vacation Management System with Next.js and PostgreSQL",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "node scripts/setup-db.js",
    "db:seed": "node scripts/seed-db.js",
    "db:reset": "node scripts/reset-db.js",
    "db:migrate": "node scripts/migrate-schema.js",
    "db:migrate-balances": "node scripts/migrate-leave-balances.js",
    "db:migrate-employees": "node scripts/migrate-employees.js",
    "db:migrate-approvals": "node scripts/migrate-approvals.js",
    "seed": "pnpm exec prisma db seed"
  },
  "prisma": {
    "seed": "pnpm exec tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "16.3.1",
    "jsonwebtoken": "9.0.2",
    "next": "14.0.3",
    "pg": "8.11.2",
    "prisma": "^7.8.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "18.2.31",
    "@types/react-dom": "18.2.14",
    "autoprefixer": "10.4.16",
    "eslint": "8.52.0",
    "eslint-config-next": "14.0.3",
    "postcss": "8.4.31",
    "tailwindcss": "3.3.6",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  }
}
